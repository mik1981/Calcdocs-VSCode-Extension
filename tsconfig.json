{
  "compilerOptions": {
    "target": "ES2020",
    "module": "Node16",
    "sourceMap": true,
    "outDir": "out",
    "rootDir": "src",
    "strict": true,
    "skipLibCheck": true,
    "moduleResolution": "Node16",
    "esModuleInterop": true, 
    "types": ["node", "vscode"] 
  },
  "include": ["src/**/*.ts"]
}
